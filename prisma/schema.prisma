generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuarios {
  id     Int @id @default(autoincrement()) 
  nome   String
  email  String @unique
  senha  String
  movimentacao Movimentacoes[]
}

model Produto {
  id            Int @id @default(autoincrement()) 
  nome          String 
  categoria     String
  faixa_etaria  String
  preco         Decimal(10,2)
  qtd_atual     Int
  qtd_minima    Int
  movimentacao Movimentacoes[]
}

model Movimentacao {
  id    Int @id @default(autoincrement()) 
  tipo  String
  quantidade Int
  data DateTime   @default(now())

  produto    Produto  @relation(fields: [produtoId], references: [id])
  produtoId  Int
}